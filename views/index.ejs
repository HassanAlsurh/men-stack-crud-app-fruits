<%- include('./partials/nav') %> 

       <div class="index-header-div">
     <h1>All Fruits</h1>
     <a class="add-fruit" href="/fruits/new">Add fruit</a>
   </div>
      <ul>
    <% fruits.forEach((item) => { %>
        <a class="fruit-cards"  href="/fruits/<%= item._id %>">
            <li><%= item.name %></li>
        </a>
    <% }); %>
  </ul>
     <p>An app for collecting your favorite fruits.</p>

  </body>
</html>
